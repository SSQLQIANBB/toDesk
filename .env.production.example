NODE_ENV=production
PORT=3000

# Public domain, without http:// or https://
DOMAIN=desk.example.com

# Server-level shared infrastructure network
SHARED_SERVICES_NETWORK=shared-services

# MySQL
DB_HOST=shared-mysql
DB_PORT=3306
DB_NAME=todesk
DB_USER=todesk
DB_PASSWORD=change-me-todesk-db-password
DB_AUTO_CREATE=false
DB_SYNC_ALTER=false
DB_LOGGING=false

# Redis
REDIS_HOST=shared-redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DB=1

# JWT
JWT_SECRET=change-me-with-a-long-random-secret
REFRESH_TOKEN_SECRET=change-me-with-another-long-random-secret
